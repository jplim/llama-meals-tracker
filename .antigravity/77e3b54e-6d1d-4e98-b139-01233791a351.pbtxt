        target_content: "          {isAddingExpense ? (\n            <ExpenseForm\n              key=\"expense-form\"\n              friends={friends}\n              onAddExpense={handleAddExpense}\n              onCancel={() => {\n                setIsAddingExpense(false);\n                setPreselectedFormPayer(undefined);\n              }}\n              preselectedPayer={preselectedFormPayer}\n            />\n          ) :"
        replacement_content: "          {isAddingExpense ? (\n            <motion.div\n              key=\"expense-form-wrapper\"\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n            >\n              <ExpenseForm\n                friends={friends}\n                onAddExpense={handleAddExpense}\n                onCancel={() => {\n                  setIsAddingExpense(false);\n                  setPreselectedFormPayer(undefined);\n                }}\n                preselectedPayer={preselectedFormPayer}\n              />\n            </motion.div>\n          ) :"
      }
      num_matches: 1
    }
  }
